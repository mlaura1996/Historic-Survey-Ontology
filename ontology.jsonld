  "@id" : "https://w3id.org/hsv#Publication",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A scholarly or technical text documenting survey findings, research, or heritage knowledge."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Publication"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/hsv#Document"
  } ]
}, {
  "@id" : "https://w3id.org/hsv#Region",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A geographic or administrative region that may contain one or more historic centres."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Region"
  } ]
}, {
  "@id" : "https://w3id.org/hsv#SeismicZone",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A zone characterised by a specific seismic hazard level, associated with a region or historic centre."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Seismic Zone"
  } ]
}, {
  "@id" : "https://w3id.org/hsv#StructuralUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A building-scale structural entity representing an individual unit within an aggregate."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Structural Unit"
  } ]
}, {
  "@id" : "https://w3id.org/hsv#TraditionalConstructionTechnique",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A construction technique or masonry system historically used in a region or historic centre."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Traditional Construction Technique"
  } ]
}, {
  "@id" : "https://w3id.org/hsv#acquiredBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
