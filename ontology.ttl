@base <https://w3id.org/hsv#> .

<https://w3id.org/hsv> rdf:type owl:Ontology ;
                        <http://purl.org/dc/terms/creator> _:genid1 ,
                                                           _:genid2 ,
                                                           _:genid3 ,
                                                           _:genid4 ,
                                                           _:genid5 ,
                                                           _:genid6 ,
                                                           _:genid7 ,
                                                           _:genid8 ;
                        <http://purl.org/dc/terms/description> "The Historic Survey Ontology (HSV) organises the knowledge involved in historic survey activities by explicitly modelling both the information sources and actors directly or indirectly involved in the survey."@en ;
                        <http://purl.org/dc/terms/isReferencedBy> <https://doi.org/10.19282/acs.13.2025.16> ;
                        <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                        <http://purl.org/dc/terms/title> "Historic Survey Ontology (HSV)"@en ;
                        <http://purl.org/vocab/vann/preferredNamespacePrefix> "hsv" ;
                        <http://purl.org/vocab/vann/preferredNamespaceUri> "https://w3id.org/hsv#" ;
                        owl:versionInfo "1.0.0" .

