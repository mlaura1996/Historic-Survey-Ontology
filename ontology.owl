    <!-- https://w3id.org/hsv#acquiredBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#acquiredBy">
        <rdfs:domain rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:range rdf:resource="https://w3id.org/hsv#Inspector"/>
        <rdfs:comment xml:lang="en">Links a survey resource to the inspector who acquired it.</rdfs:comment>
        <rdfs:label xml:lang="en">acquired by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#contains -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#contains">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/hsv#Aggregate"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#HistoricCentre"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#Region"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/hsv#Aggregate"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#HistoricCentre"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#StructuralUnit"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">A generic spatial containment property linking a larger spatial entity to a smaller one nested within it.</rdfs:comment>
        <rdfs:label xml:lang="en">contains</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasAuthor -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasAuthor">
        <rdfs:domain rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:range rdf:resource="https://w3id.org/hsv#Author"/>
        <rdfs:comment xml:lang="en">Links a document or publication to its author.</rdfs:comment>
        <rdfs:label xml:lang="en">has author</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasDocument -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasDocument">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/hsv#Aggregate"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#Facade"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#HistoricCentre"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#Region"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#StructuralUnit"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">Links a spatial, structural, or material entity to a document that provides evidence for its characterisation.</rdfs:comment>
        <rdfs:label xml:lang="en">has document</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasInspector -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasInspector">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/hsv#acquiredBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:range rdf:resource="https://w3id.org/hsv#Inspector"/>
        <rdfs:comment xml:lang="en">Associates a survey resource with the inspector responsible for its field acquisition.</rdfs:comment>
        <rdfs:label xml:lang="en">has inspector</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasPostProcesser -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasPostProcesser">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/hsv#postProcessedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:range rdf:resource="https://w3id.org/hsv#PostProcesser"/>
        <rdfs:comment xml:lang="en">Associates a survey resource with the post-processer responsible for its elaboration.</rdfs:comment>
        <rdfs:label xml:lang="en">has post-processer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasSeismicZone -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasSeismicZone">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/hsv#HistoricCentre"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#Region"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/hsv#SeismicZone"/>
        <rdfs:comment xml:lang="en">Associates a region or historic centre with its seismic zone classification.</rdfs:comment>
        <rdfs:label xml:lang="en">has seismic zone</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#hasTraditionalConstructionTechnique -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#hasTraditionalConstructionTechnique">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/hsv#HistoricCentre"/>
                    <rdf:Description rdf:about="https://w3id.org/hsv#Region"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/hsv#TraditionalConstructionTechnique"/>
        <rdfs:comment xml:lang="en">Associates a region or historic centre with a traditional construction technique typical of that context.</rdfs:comment>
        <rdfs:label xml:lang="en">has traditional construction technique</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#isContainedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#isContainedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/hsv#contains"/>
        <rdfs:comment xml:lang="en">Inverse of hsv:contains.</rdfs:comment>
        <rdfs:label xml:lang="en">is contained by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#isDocumentOf -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#isDocumentOf">
        <owl:inverseOf rdf:resource="https://w3id.org/hsv#hasDocument"/>
        <rdfs:comment xml:lang="en">Inverse of hsv:hasDocument.</rdfs:comment>
        <rdfs:label xml:lang="en">is document of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/hsv#postProcessedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/hsv#postProcessedBy">
        <rdfs:domain rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:range rdf:resource="https://w3id.org/hsv#PostProcesser"/>
        <rdfs:comment xml:lang="en">Links a survey resource to the person who post-processed it.</rdfs:comment>
        <rdfs:label xml:lang="en">post-processed by</rdfs:label>
    </owl:ObjectProperty>
    


