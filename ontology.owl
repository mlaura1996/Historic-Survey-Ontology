    <!-- http://xmlns.com/foaf/0.1/Person -->


    <owl:Class rdf:about="http://xmlns.com/foaf/0.1/Person"/>
    


    <!-- https://w3id.org/hsv#Aggregate -->


    <owl:Class rdf:about="https://w3id.org/hsv#Aggregate">
        <rdfs:comment xml:lang="en">A building aggregate typical of historic urban fabrics, composed of one or more structural units.</rdfs:comment>
        <rdfs:label xml:lang="en">Aggregate</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Author -->


    <owl:Class rdf:about="https://w3id.org/hsv#Author">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">A person who authored a document or publication related to the survey.</rdfs:comment>
        <rdfs:label xml:lang="en">Author</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#BuildingInformationModel -->


    <owl:Class rdf:about="https://w3id.org/hsv#BuildingInformationModel">
        <rdfs:subClassOf rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">A digital model representing the physical and functional characteristics of a heritage asset (BIM).</rdfs:comment>
        <rdfs:label xml:lang="en">Building Information Model</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Document -->


    <owl:Class rdf:about="https://w3id.org/hsv#Document">
        <rdfs:comment xml:lang="en">A central class representing any survey output or information source associated with a heritage asset or its components.</rdfs:comment>
        <rdfs:label xml:lang="en">Document</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Drawing -->


    <owl:Class rdf:about="https://w3id.org/hsv#Drawing">
        <rdfs:subClassOf rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">A graphical representation such as a plan, section, or elevation produced during a survey.</rdfs:comment>
        <rdfs:label xml:lang="en">Drawing</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Facade -->


    <owl:Class rdf:about="https://w3id.org/hsv#Facade">
        <rdfs:comment xml:lang="en">The exterior face of a structural unit or building, treated as a distinct survey entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Facade</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#HistoricCentre -->


    <owl:Class rdf:about="https://w3id.org/hsv#HistoricCentre">
        <rdfs:comment xml:lang="en">A historic urban centre, typically nested within a region, that may contain one or more building aggregates.</rdfs:comment>
        <rdfs:label xml:lang="en">Historic Centre</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Inspector -->


    <owl:Class rdf:about="https://w3id.org/hsv#Inspector">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">A person responsible for acquiring survey data in the field.</rdfs:comment>
        <rdfs:label xml:lang="en">Inspector</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Photo -->


    <owl:Class rdf:about="https://w3id.org/hsv#Photo">
        <rdfs:subClassOf rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">A photographic record of a heritage asset or its components acquired during survey activities.</rdfs:comment>
        <rdfs:label xml:lang="en">Photo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#PointCloud -->


    <owl:Class rdf:about="https://w3id.org/hsv#PointCloud">
        <rdfs:subClassOf rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">A set of data points in 3D space acquired through laser scanning or photogrammetry.</rdfs:comment>
        <rdfs:label xml:lang="en">Point Cloud</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#PostProcesser -->


    <owl:Class rdf:about="https://w3id.org/hsv#PostProcesser">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:comment xml:lang="en">A person responsible for the post-processing of raw survey data into usable outputs.</rdfs:comment>
        <rdfs:label xml:lang="en">Post-Processer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Publication -->


    <owl:Class rdf:about="https://w3id.org/hsv#Publication">
        <rdfs:subClassOf rdf:resource="https://w3id.org/hsv#Document"/>
        <rdfs:comment xml:lang="en">A scholarly or technical text documenting survey findings, research, or heritage knowledge.</rdfs:comment>
        <rdfs:label xml:lang="en">Publication</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#Region -->


    <owl:Class rdf:about="https://w3id.org/hsv#Region">
        <rdfs:comment xml:lang="en">A geographic or administrative region that may contain one or more historic centres.</rdfs:comment>
        <rdfs:label xml:lang="en">Region</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#SeismicZone -->


    <owl:Class rdf:about="https://w3id.org/hsv#SeismicZone">
        <rdfs:comment xml:lang="en">A zone characterised by a specific seismic hazard level, associated with a region or historic centre.</rdfs:comment>
        <rdfs:label xml:lang="en">Seismic Zone</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#StructuralUnit -->


    <owl:Class rdf:about="https://w3id.org/hsv#StructuralUnit">
        <rdfs:comment xml:lang="en">A building-scale structural entity representing an individual unit within an aggregate.</rdfs:comment>
        <rdfs:label xml:lang="en">Structural Unit</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/hsv#TraditionalConstructionTechnique -->


    <owl:Class rdf:about="https://w3id.org/hsv#TraditionalConstructionTechnique">
        <rdfs:comment xml:lang="en">A construction technique or masonry system historically used in a region or historic centre.</rdfs:comment>
        <rdfs:label xml:lang="en">Traditional Construction Technique</rdfs:label>
    </owl:Class>
</rdf:RDF>



